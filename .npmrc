# pnpm configuration for the ExamForge monorepo.

# Hoist only specific packages to the root node_modules.
# Prevents phantom dependency bugs — packages must declare their own deps.
shamefully-hoist=false
hoist-pattern[]=*eslint*
hoist-pattern[]=*prettier*
hoist-pattern[]=*typescript*

# Fail on peer dependency conflicts (catches version mismatches early).
strict-peer-dependencies=false
auto-install-peers=true

# Link workspace packages via symlinks (default true, making it explicit).
link-workspace-packages=true

# Store location (default is fine; explicit for documentation).
# store-dir=~/.pnpm-store

# Ensure the lockfile is up to date — fail CI if someone forgot to commit it.
frozen-lockfile=false

# Engine checks — respect the "engines" field in package.json.
engine-strict=true
