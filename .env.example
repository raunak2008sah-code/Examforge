# =============================================================================
# ExamForge — Environment Variables
# =============================================================================
#
# INSTRUCTIONS
# ------------
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in every value marked <required>.
# 3. Never commit .env — it is in .gitignore.
# 4. Production secrets live in Vercel / Railway / Supabase dashboards only.
#
# SECTIONS
# --------
#   A. Database
#   B. Authentication (Server Only)
#   C. Supabase Storage
#   D. Service-to-Service
#   E. Client-Safe (NEXT_PUBLIC_*)
#
# =============================================================================


# =============================================================================
# A. DATABASE — Server Only
# =============================================================================

# PostgreSQL connection string for Prisma.
# Local dev:      postgresql://postgres:postgres@localhost:5432/examforge
# Supabase:       find in Supabase dashboard → Settings → Database → Connection string (URI)
# Never expose this to the client bundle.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/examforge"

# Direct connection URL (bypasses PgBouncer — required for migrations).
# Supabase: Settings → Database → Connection string → select "Direct connection"
# Only needed in CI and when running `prisma migrate deploy`.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/examforge"


# =============================================================================
# B. AUTHENTICATION — Server Only (Better Auth)
# =============================================================================

# Secret used to sign session tokens. Generate with:  openssl rand -base64 32
# Required. Min 32 characters.
BETTER_AUTH_SECRET="<required: generate with openssl rand -base64 32>"

# Canonical URL of this application (no trailing slash).
# Local dev: http://localhost:3000
# Production: https://examforge.yourdomain.com
BETTER_AUTH_URL="http://localhost:3000"


# =============================================================================
# C. SUPABASE STORAGE — Server Only
# =============================================================================

# Supabase project URL. Find in: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL="<required: https://xxxxxxxxxxxx.supabase.co>"

# Service role key — bypasses Row Level Security. NEVER expose to the client.
# Find in: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="<required: eyJ...>"

# Anonymous / public key — safe to expose but we keep it server-side for storage ops.
# Find in: Supabase dashboard → Settings → API → anon / public key
SUPABASE_ANON_KEY="<required: eyJ...>"


# =============================================================================
# D. SERVICE-TO-SERVICE — Server Only
# =============================================================================

# Shared secret for the doc-processor → Next.js parser callback (CLAUDE.md §4.4).
# Generate with:  openssl rand -hex 32
# Must match the value set in apps/doc-processor environment (Railway/Render).
PARSER_CALLBACK_SECRET="<required: generate with openssl rand -hex 32>"

# Base URL of the doc-processor service (no trailing slash).
# Local dev: http://localhost:8000
# Production: https://your-processor.railway.app
PROCESSOR_URL="http://localhost:8000"


# =============================================================================
# E. CLIENT-SAFE — Safe to expose in the browser (NEXT_PUBLIC_*)
# =============================================================================
# These values are inlined into the client JS bundle by Next.js.
# Never put secrets here.

# Canonical URL sent to the browser (used by Better Auth client, absolute links).
# Must match BETTER_AUTH_URL exactly.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
