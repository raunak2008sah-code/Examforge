# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across editors and IDEs.
# Prettier handles the heavy lifting; this file catches editors that don't run Prettier.

root = true

# ---------------------------------------------------------------------------
# Defaults — all files
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ---------------------------------------------------------------------------
# TypeScript / JavaScript / JSON / YAML / CSS / MDX
# ---------------------------------------------------------------------------
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yaml,yml,css,scss,md,mdx}]
indent_size = 2

# ---------------------------------------------------------------------------
# Python — PEP 8 uses 4-space indentation
# ---------------------------------------------------------------------------
[*.py]
indent_size = 4
max_line_length = 100

# ---------------------------------------------------------------------------
# Makefile — tabs are required by Make
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab

# ---------------------------------------------------------------------------
# TOML — Python project config
# ---------------------------------------------------------------------------
[*.toml]
indent_size = 4

# ---------------------------------------------------------------------------
# Shell scripts
# ---------------------------------------------------------------------------
[*.{sh,bash}]
indent_size = 4

# ---------------------------------------------------------------------------
# Prisma schema
# ---------------------------------------------------------------------------
[*.prisma]
indent_size = 2
