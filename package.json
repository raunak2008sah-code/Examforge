{
  "name": "examforge",
  "version": "0.1.0",
  "private": true,
  "description": "ExamForge — JEE Main CBT platform with document processing pipeline",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/examforge/examforge.git"
  },
  "scripts": {
    "dev": "pnpm --filter @examforge/web dev",
    "dev:web": "pnpm --filter @examforge/web dev",
    "build": "pnpm -r --filter @examforge/db --filter @examforge/shared-types build && pnpm --filter @examforge/web build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean && rimraf node_modules",
    "install:all": "pnpm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "prettier": "3.4.2",
    "rimraf": "6.0.1",
    "typescript": "5.6.3"
  }
}
