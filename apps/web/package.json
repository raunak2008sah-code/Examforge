{
  "name": "@examforge/web",
  "version": "0.1.0",
  "private": true,
  "description": "ExamForge Next.js web application — admin dashboard and CBT engine",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:staged": "eslint --fix --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify:auth": "tsx scripts/verify-auth-flow.ts",
    "verify:authorization": "tsx scripts/verify-authorization-flow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf .next out dist"
  },
  "dependencies": {
    "@examforge/db": "workspace:^",
    "better-auth": "^1.6.23",
    "next": "15.3.9",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "20.17.10",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.28.0",
    "eslint-config-next": "15.3.9",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "vitest": "3.2.6"
  }
}
